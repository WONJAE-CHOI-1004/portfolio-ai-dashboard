# Streamlit Cloud 배포용 시크릿 예시.
# 앱 대시보드 → Manage app → Settings → Secrets 에 아래 내용을 붙여넣으세요.
# ⚠️ 실제 값이 담긴 secrets.toml 은 절대 GitHub에 올리지 마세요(.gitignore로 제외됨).

# 무료 Gemini 키: https://aistudio.google.com/apikey
GOOGLE_API_KEY = "여기에_Gemini_API_키"

# 이메일 발송(Brevo 권장)
EMAIL_BACKEND = "brevo"                 # gmail | brevo | sendgrid
EMAIL_API_KEY = "여기에_Brevo_API_키"    # xkeysib-... (gmail 백엔드면 비워두고 GMAIL_APP_PASSWORD 사용)
EMAIL_SENDER = "cwj09501@gmail.com"     # Brevo에서 인증한 발신자
EMAIL_RECIPIENT = "cwj09501@gmail.com"  # 내 리포트 받을 주소

# 공개 배포 시 대시보드 보호(방문자는 구독 기능만, 소유자만 로그인 후 전체)
OWNER_PASSWORD = "원하는_소유자_비밀번호"

# 배포 후 실제 앱 주소 (구독 확인/수신거부 링크에 사용)
BASE_URL = "https://your-app-name.streamlit.app"

# (gmail 백엔드를 쓸 때만) Gmail 앱 비밀번호
# GMAIL_APP_PASSWORD = "16자리_앱_비밀번호"
